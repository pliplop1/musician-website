# Image publiée par la CI (GHCR)
APP_IMAGE=ghcr.io/ORG/REPO:latest

# Profil Spring
SPRING_PROFILES_ACTIVE=prod

# Base de données (externe ou conteneur)
DATABASE_URL=jdbc:mariadb://db-host:3306/musician_db?useSSL=false&allowPublicKeyRetrieval=true
DATABASE_USERNAME=musician_user
DATABASE_PASSWORD=musician_password

# Email (optionnel)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@duoblackandwhite.com
ADMIN_EMAIL=

# Réseau/Ports
APP_PORT=8080
SERVER_PORT=8080

# JVM
JAVA_OPTS=-Xms512m -Xmx1024m

# Proxy HTTPS (Caddy)
DOMAIN=example.com
ACME_EMAIL=admin@example.com
