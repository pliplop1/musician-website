# =============================================================
# Variables d'environnement pour Docker Compose
# =============================================================
# Copiez ce fichier en .env et modifiez les valeurs selon vos besoins
# =============================================================

# =============================================================
# DATABASE
# =============================================================
DB_ROOT_PASSWORD=root_password_change_me
DB_NAME=musician_db
DB_USER=musician_user
DB_PASSWORD=musician_password_change_me
DB_PORT=3306

# =============================================================
# APPLICATION
# =============================================================
APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# =============================================================
# JAVA OPTIONS
# =============================================================
JAVA_OPTS=-Xms512m -Xmx1024m

# =============================================================
# EMAIL (optionnel - si vous utilisez l'envoi d'emails)
# =============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@duoblackandwhite.com
ADMIN_EMAIL=dumoulin.marilyne@gmail.com

# =============================================================
# ADMINER (interface web pour la base de données)
# =============================================================
ADMINER_PORT=8081
